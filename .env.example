# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_api_key"

# JWT_ACCESS_SECRET: Cryptographic secret for signing access tokens
JWT_ACCESS_SECRET="synapse-ai-access-quantum-secret-2026"

# JWT_REFRESH_SECRET: Cryptographic secret for signing refresh tokens
JWT_REFRESH_SECRET="synapse-ai-refresh-quantum-secret-2026"

# CLIENT_URL: The trusted web address (domain/URL) where the browser interface of the application is running. 
# The server uses this to securely let your browser talk to backend APIs and web sockets (CORS).
CLIENT_URL="http://localhost:3000"

# NODE_ENV: Runtime deployment tier (e.g., development, production)
NODE_ENV="development"

# JWT_SECRET: Security token decryption seed for authenticating collaborators.
JWT_SECRET="synapse-ai-exclusive-quantum-secret-2026"

# MONGODB_URI: (Optional) The connection URI for your MongoDB database (e.g. MongoDB Atlas).
# If not provided, SynapseAI automatically runs in high-performance Local JSON Persistent mode.
MONGODB_URI="MongoDB Atlas URI"

# Initial Platform Administration Credentials (MERN System Startup Auto-Seeder)
ADMIN_NAME="System Super Administrator"
ADMIN_EMAIL="admin@synapse.ai"
ADMIN_PASSWORD="Password@123"
